# 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일을 만들고 실제 키를 입력하세요

# Groq API 키
# 발급: https://console.groq.com → API Keys
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY

# NEIS 교육정보시스템 API 키 (전국 학교 검색용)
# 발급: https://open.neis.go.kr → 인증키 신청 (무료)
# 이 키가 없으면 제한된 검색만 가능합니다
VITE_NEIS_API_KEY=YOUR_NEIS_API_KEY

# 학교알리미 Open API 키 (상세 학생수 현황용)
# 발급: https://www.schoolinfo.go.kr → OpenAPI → 인증키 발급
VITE_SCHOOLINFO_API_KEY=YOUR_SCHOOLINFO_API_KEY

# Supabase 설정
# 발급: https://supabase.com → 프로젝트 → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
